# ====================== 服务配置 ======================
APP_HOST=0.0.0.0
APP_PORT=8000
ENV_MODE=dev

# ====================== 鉴权/密钥 ======================
API_KEY=your_api_key_here
API_TOKEN=your_token_here

# ====================== PostgreSQL 数据库 ======================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PWD=your_db_password
DB_NAME=fastapi_chat_db

# ====================== Redis 缓存 ======================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL_NORMAL=1800
CACHE_TTL_EMPTY=300
